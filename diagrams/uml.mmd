classDiagram
class Owner {
    +String name
    +String email
    +String preferences
    +List~Pet~ pets
    +add_pet(pet)
    +remove_pet(pet_name)
    +get_pets()
}

class Pet {
    +String name
    +String species
    +String breed
    +int age
    +List~Task~ tasks
    +add_task(task)
    +remove_task(task_name)
    +get_tasks()
}

class Task {
    +String name
    +String category
    +int duration_minutes
    +int priority
    +bool completed
    +mark_complete()
    +is_high_priority()
}

class Scheduler {
    +int available_minutes
    +List~Task~ tasks
    +add_task(task)
    +sort_tasks_by_priority()
    +detect_conflicts()
    +generate_daily_plan()
}

Owner "1" --> "*" Pet : owns
Pet "1" --> "*" Task : has
Scheduler "1" --> "*" Task : schedules